---
import AdminLayout from "@layouts/AdminLayout.astro";
---

<AdminLayout title="Dashboard" activePage="dashboard">
  <div id="stats" class="admin-stats">
    <div class="stat-card">
      <span class="stat-card-value" id="stat-total">—</span>
      <span class="stat-card-label">Total Products</span>
    </div>
    <div class="stat-card stat-card--green">
      <span class="stat-card-value" id="stat-available">—</span>
      <span class="stat-card-label">Available</span>
    </div>
    <div class="stat-card stat-card--red">
      <span class="stat-card-value" id="stat-oos">—</span>
      <span class="stat-card-label">Out of Stock</span>
    </div>
    <div class="stat-card stat-card--orange">
      <span class="stat-card-value" id="stat-categories">—</span>
      <span class="stat-card-label">Categories</span>
    </div>
  </div>

  <div class="admin-card">
    <div class="admin-card-header">
      <h2>Recent Products</h2>
      <a class="btn btn--primary btn--sm" href="/admin/products/add/">
        + Add Product
      </a>
    </div>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Category</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="recent-products">
          <tr><td colspan="5" style="text-align:center;padding:32px;color:var(--muted)">Loading…</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script type="module">
  import { api } from "/admin/utils.js";

  async function load() {
    const [productsRes, categoriesRes] = await Promise.all([
      api("/api/products"),
      api("/api/categories"),
    ]);

    if (!productsRes || !categoriesRes) return;

    const products   = await productsRes.json();
    const categories = await categoriesRes.json();

    document.getElementById("stat-total").textContent      = products.length;
    document.getElementById("stat-available").textContent  = products.filter(p => p.status === "available").length;
    document.getElementById("stat-oos").textContent        = products.filter(p => p.status === "out-of-stock").length;
    document.getElementById("stat-categories").textContent = categories.length;

    const tbody = document.getElementById("recent-products");

    if (!products.length) {
      tbody.innerHTML = `<tr><td colspan="5"><div class="admin-empty"><p>No products yet.</p><a class="btn btn--primary btn--sm" href="/admin/products/add/">Add your first product</a></div></td></tr>`;
      return;
    }

    tbody.innerHTML = products.slice(0, 8).map(p => `
      <tr>
        <td><img class="admin-table-img" src="${p.image_url || '/mspc-logo.png'}" alt="${p.name}" /></td>
        <td><span class="admin-table-name">${p.name}</span></td>
        <td>${p.category_name ?? "—"}</td>
        <td><span class="status-badge status-badge--${p.status}">${p.status.replace("-", " ")}</span></td>
        <td>
          <div class="admin-table-actions">
            <a class="btn btn--ghost btn--sm" href="/admin/products/edit/?id=${p.id}">Edit</a>
            <a class="btn btn--ghost btn--sm" href="/products/${p.slug}/" target="_blank">View</a>
          </div>
        </td>
      </tr>
    `).join("");
  }

  load();
</script>
