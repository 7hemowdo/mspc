---
import AdminLayout from "@layouts/AdminLayout.astro";
---

<AdminLayout title="Edit Product" activePage="products">
  <div slot="topbar-actions">
    <a class="btn btn--ghost" href="/admin/products/">← Back</a>
  </div>

  <div id="loading-state" style="padding:48px;text-align:center;color:var(--muted)">Loading product…</div>

  <div class="admin-card" style="max-width:860px;display:none" id="form-card">
    <div class="admin-card-body">
      <form class="admin-form" id="product-form" novalidate>

        <div class="form-row">
          <div class="form-group">
            <label for="name">Product Name *</label>
            <input class="form-input" id="name" type="text" required />
          </div>
          <div class="form-group">
            <label for="category">Category *</label>
            <select class="form-select" id="category" required>
              <option value="">Select a category…</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="slug">URL Slug</label>
          <input class="form-input" id="slug" type="text" />
          <p class="form-hint">Changing the slug will break existing links to this product.</p>
        </div>

        <div class="form-group">
          <label for="short-desc">Short Description *</label>
          <input class="form-input" id="short-desc" type="text" required />
        </div>

        <div class="form-group">
          <label for="full-desc">Full Description</label>
          <textarea class="form-textarea" id="full-desc" rows="5"></textarea>
        </div>

        <div class="form-group">
          <label>Product Image</label>
          <div class="image-upload">
            <div class="image-dropzone" id="dropzone">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              <p><strong>Click to upload</strong> or drag and drop</p>
              <p>JPEG, PNG, WebP — max 10MB</p>
              <input type="file" id="image-file" accept="image/jpeg,image/png,image/webp" />
            </div>
            <div class="image-preview" id="image-preview">
              <img id="preview-img" src="" alt="Preview" />
              <button class="image-preview-remove" type="button" id="remove-image">✕</button>
            </div>
          </div>
          <input type="hidden" id="image-url" />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="status">Status</label>
            <select class="form-select" id="status">
              <option value="available">Available</option>
              <option value="out-of-stock">Out of Stock</option>
              <option value="hidden">Hidden</option>
            </select>
          </div>
        </div>

        <div style="display:grid;gap:14px">
          <label class="form-toggle">
            <input type="checkbox" id="is-featured" />
            <div class="form-toggle-label">
              <strong>Featured Product</strong>
              <span>Shown in the Featured Products section</span>
            </div>
          </label>
          <label class="form-toggle">
            <input type="checkbox" id="is-new-arrival" />
            <div class="form-toggle-label">
              <strong>New Arrival</strong>
              <span>Shown in the New Arrivals section</span>
            </div>
          </label>
        </div>

        <div class="form-group">
          <label>Specifications</label>
          <div class="specs-list" id="specs-list"></div>
          <button class="btn btn--ghost btn--sm" type="button" id="add-spec" style="margin-top:10px;align-self:start">
            + Add Specification
          </button>
        </div>

        <div class="form-actions">
          <button class="btn btn--primary" type="submit" id="submit-btn">Save Changes</button>
          <a class="btn btn--ghost" href="/admin/products/">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script type="module">
  import { api, showToast, setLoading } from "/admin/utils.js";

  const params    = new URLSearchParams(window.location.search);
  const productId = params.get("id");

  if (!productId) {
    window.location.href = "/admin/products/";
  }

  // ─── Load categories + product ────────────────────────────────────────
  const [catsRes, productRes] = await Promise.all([
    api("/api/categories"),
    api(`/api/products/${productId}`),
  ]);

  if (!catsRes || !productRes) {
    document.getElementById("loading-state").textContent = "Failed to load product.";
    return;
  }

  const categories = await catsRes.json();
  const product    = await productRes.json();

  const catSelect = document.getElementById("category");
  categories.forEach(c => {
    const opt = document.createElement("option");
    opt.value = c.id;
    opt.textContent = c.name;
    if (c.id === product.category_id) opt.selected = true;
    catSelect.appendChild(opt);
  });

  // ─── Fill form ────────────────────────────────────────────────────────
  document.getElementById("name").value       = product.name;
  document.getElementById("slug").value       = product.slug;
  document.getElementById("short-desc").value = product.short_description;
  document.getElementById("full-desc").value  = product.full_description;
  document.getElementById("status").value     = product.status;
  document.getElementById("is-featured").checked    = Boolean(product.is_featured);
  document.getElementById("is-new-arrival").checked = Boolean(product.is_new_arrival);
  document.getElementById("image-url").value = product.image_url;

  if (product.image_url) {
    document.getElementById("preview-img").src = product.image_url;
    document.getElementById("image-preview").classList.add("has-image");
    document.getElementById("dropzone").style.display = "none";
  }

  if (product.specs?.length) {
    product.specs.forEach(s => addSpecRow(s.label, s.value));
  }

  document.getElementById("loading-state").style.display = "none";
  document.getElementById("form-card").style.display = "";

  // ─── Image upload ─────────────────────────────────────────────────────
  const dropzone    = document.getElementById("dropzone");
  const fileInput   = document.getElementById("image-file");
  const preview     = document.getElementById("image-preview");
  const previewImg  = document.getElementById("preview-img");
  const imageUrlInput = document.getElementById("image-url");

  dropzone.addEventListener("click", () => fileInput.click());
  dropzone.addEventListener("dragover",  (e) => { e.preventDefault(); dropzone.classList.add("dragover"); });
  dropzone.addEventListener("dragleave", () => dropzone.classList.remove("dragover"));
  dropzone.addEventListener("drop", (e) => {
    e.preventDefault();
    dropzone.classList.remove("dragover");
    if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener("change", (e) => { if (e.target.files[0]) handleFile(e.target.files[0]); });

  document.getElementById("remove-image").addEventListener("click", () => {
    imageUrlInput.value = "";
    previewImg.src = "";
    preview.classList.remove("has-image");
    dropzone.style.display = "";
    fileInput.value = "";
  });

  async function handleFile(file) {
    dropzone.style.display = "none";
    preview.classList.add("has-image");
    previewImg.src = URL.createObjectURL(file);

    const form = new FormData();
    form.append("file", file);
    const res = await api("/api/upload", { method: "POST", body: form, multipart: true });
    if (res?.ok) {
      const { url } = await res.json();
      imageUrlInput.value = url;
    } else {
      showToast("Image upload failed", "error");
    }
  }

  // ─── Specs ───────────────────────────────────────────────────────────
  function addSpecRow(label = "", value = "") {
    const row = document.createElement("div");
    row.className = "spec-row";
    row.innerHTML = `
      <input class="form-input spec-label" type="text" placeholder="Label" value="${label}" />
      <input class="form-input spec-value" type="text" placeholder="Value" value="${value}" />
      <button class="spec-row-remove" type="button" title="Remove">✕</button>
    `;
    row.querySelector(".spec-row-remove").addEventListener("click", () => row.remove());
    document.getElementById("specs-list").appendChild(row);
  }

  document.getElementById("add-spec").addEventListener("click", () => addSpecRow());

  // ─── Submit ──────────────────────────────────────────────────────────
  document.getElementById("product-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = document.getElementById("submit-btn");

    const name     = document.getElementById("name").value.trim();
    const category = document.getElementById("category").value;
    if (!name || !category) { showToast("Name and category are required", "error"); return; }

    const specs = [...document.querySelectorAll(".spec-row")].map(row => ({
      label: row.querySelector(".spec-label").value.trim(),
      value: row.querySelector(".spec-value").value.trim(),
    })).filter(s => s.label && s.value);

    const payload = {
      name,
      category_id:       Number(category),
      slug:              document.getElementById("slug").value.trim(),
      short_description: document.getElementById("short-desc").value.trim(),
      full_description:  document.getElementById("full-desc").value.trim(),
      image_url:         document.getElementById("image-url").value.trim(),
      status:            document.getElementById("status").value,
      is_featured:       document.getElementById("is-featured").checked ? 1 : 0,
      is_new_arrival:    document.getElementById("is-new-arrival").checked ? 1 : 0,
      specs,
    };

    setLoading(btn, true);
    const res = await api(`/api/products/${productId}`, { method: "PUT", body: payload });

    if (res?.ok) {
      showToast("Product saved!");
      setTimeout(() => window.location.href = "/admin/products/", 800);
    } else {
      showToast("Failed to save changes", "error");
      setLoading(btn, false);
    }
  });
</script>
