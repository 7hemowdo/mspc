---
import AdminLayout from "@layouts/AdminLayout.astro";
---

<AdminLayout title="Add Product" activePage="products">
  <div slot="topbar-actions">
    <a class="btn btn--ghost" href="/admin/products/">← Back</a>
  </div>

  <div class="admin-card" style="max-width:860px">
    <div class="admin-card-body">
      <form class="admin-form" id="product-form" novalidate>

        <div class="form-row">
          <div class="form-group">
            <label for="name">Product Name *</label>
            <input class="form-input" id="name" type="text" placeholder="e.g. Ubiquiti NanoStation M5" required />
          </div>
          <div class="form-group">
            <label for="category">Category *</label>
            <select class="form-select" id="category" required>
              <option value="">Select a category…</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="slug">URL Slug</label>
          <input class="form-input" id="slug" type="text" placeholder="auto-generated from name" />
          <p class="form-hint">Leave blank to auto-generate. Use lowercase letters and hyphens only.</p>
        </div>

        <div class="form-group">
          <label for="short-desc">Short Description *</label>
          <input class="form-input" id="short-desc" type="text" placeholder="One line summary shown on product cards" required />
        </div>

        <div class="form-group">
          <label for="full-desc">Full Description</label>
          <textarea class="form-textarea" id="full-desc" rows="5" placeholder="Detailed product description…"></textarea>
        </div>

        <div class="form-group">
          <label>Product Image</label>
          <div class="image-upload">
            <div class="image-dropzone" id="dropzone">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              <p><strong>Click to upload</strong> or drag and drop</p>
              <p>JPEG, PNG, WebP — max 10MB</p>
              <input type="file" id="image-file" accept="image/jpeg,image/png,image/webp" />
            </div>
            <div class="image-preview" id="image-preview">
              <img id="preview-img" src="" alt="Preview" />
              <button class="image-preview-remove" type="button" id="remove-image">✕</button>
            </div>
          </div>
          <input type="hidden" id="image-url" />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="status">Status</label>
            <select class="form-select" id="status">
              <option value="available">Available</option>
              <option value="out-of-stock">Out of Stock</option>
              <option value="hidden">Hidden</option>
            </select>
          </div>
        </div>

        <div style="display:grid;gap:14px">
          <label class="form-toggle">
            <input type="checkbox" id="is-featured" />
            <div class="form-toggle-label">
              <strong>Featured Product</strong>
              <span>Shown in the Featured Products section</span>
            </div>
          </label>
          <label class="form-toggle">
            <input type="checkbox" id="is-new-arrival" />
            <div class="form-toggle-label">
              <strong>New Arrival</strong>
              <span>Shown in the New Arrivals section</span>
            </div>
          </label>
        </div>

        <div class="form-group">
          <label>Specifications</label>
          <div class="specs-list" id="specs-list"></div>
          <button class="btn btn--ghost btn--sm" type="button" id="add-spec" style="margin-top:10px;align-self:start">
            + Add Specification
          </button>
        </div>

        <div class="form-actions">
          <button class="btn btn--primary" type="submit" id="submit-btn">Publish Product</button>
          <a class="btn btn--ghost" href="/admin/products/">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script type="module">
  import { api, slugify, showToast, setLoading, validateImageFile } from "/admin/utils.js";

  // ─── Load categories ─────────────────────────────────────────────────
  const catRes = await api("/api/categories");
  if (catRes) {
    const cats = await catRes.json();
    const sel  = document.getElementById("category");
    cats.forEach(c => {
      const opt = document.createElement("option");
      opt.value = c.id;
      opt.textContent = c.name;
      sel.appendChild(opt);
    });
  }

  // ─── Auto-slug from name ─────────────────────────────────────────────
  document.getElementById("name").addEventListener("input", (e) => {
    const slugField = document.getElementById("slug");
    if (!slugField.dataset.edited) {
      slugField.value = slugify(e.target.value);
    }
  });

  document.getElementById("slug").addEventListener("input", (e) => {
    e.target.dataset.edited = e.target.value ? "true" : "";
  });

  // ─── Image upload ─────────────────────────────────────────────────────
  const dropzone    = document.getElementById("dropzone");
  const fileInput   = document.getElementById("image-file");
  const preview     = document.getElementById("image-preview");
  const previewImg  = document.getElementById("preview-img");
  const imageUrlInput = document.getElementById("image-url");

  dropzone.addEventListener("click", () => fileInput.click());

  dropzone.addEventListener("dragover", (e) => { e.preventDefault(); dropzone.classList.add("dragover"); });
  dropzone.addEventListener("dragleave", () => dropzone.classList.remove("dragover"));
  dropzone.addEventListener("drop", (e) => {
    e.preventDefault();
    dropzone.classList.remove("dragover");
    if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
  });

  fileInput.addEventListener("change", (e) => {
    if (e.target.files[0]) handleFile(e.target.files[0]);
  });

  document.getElementById("remove-image").addEventListener("click", () => {
    imageUrlInput.value = "";
    previewImg.src = "";
    preview.classList.remove("has-image");
    dropzone.style.display = "";
    fileInput.value = "";
  });

  async function handleFile(file) {
    const validationError = validateImageFile(file);
    if (validationError) { showToast(validationError, "error"); return; }

    dropzone.style.display = "none";
    preview.classList.add("has-image");
    previewImg.src = URL.createObjectURL(file);

    const form = new FormData();
    form.append("file", file);

    const res = await api("/api/upload", { method: "POST", body: form, multipart: true });
    if (res?.ok) {
      const { url } = await res.json();
      imageUrlInput.value = url;
    } else {
      showToast("Image upload failed", "error");
      preview.classList.remove("has-image");
      dropzone.style.display = "";
      imageUrlInput.value = "";
    }
  }

  // ─── Specs ───────────────────────────────────────────────────────────
  function addSpecRow(label = "", value = "") {
    const row = document.createElement("div");
    row.className = "spec-row";
    row.innerHTML = `
      <input class="form-input spec-label" type="text" placeholder="Label (e.g. Frequency)" value="${label}" />
      <input class="form-input spec-value" type="text" placeholder="Value (e.g. 5 GHz)" value="${value}" />
      <button class="spec-row-remove" type="button" title="Remove">✕</button>
    `;
    row.querySelector(".spec-row-remove").addEventListener("click", () => row.remove());
    document.getElementById("specs-list").appendChild(row);
  }

  document.getElementById("add-spec").addEventListener("click", () => addSpecRow());

  // ─── Submit ──────────────────────────────────────────────────────────
  document.getElementById("product-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = document.getElementById("submit-btn");

    const name      = document.getElementById("name").value.trim();
    const category  = document.getElementById("category").value;
    const shortDesc = document.getElementById("short-desc").value.trim();

    if (!name || !category || !shortDesc) {
      showToast("Name, category, and short description are required", "error");
      return;
    }

    const specs = [...document.querySelectorAll(".spec-row")].map(row => ({
      label: row.querySelector(".spec-label").value.trim(),
      value: row.querySelector(".spec-value").value.trim(),
    })).filter(s => s.label && s.value);

    const payload = {
      name,
      category_id: Number(category),
      slug: document.getElementById("slug").value.trim() || undefined,
      short_description: document.getElementById("short-desc").value.trim(),
      full_description:  document.getElementById("full-desc").value.trim(),
      image_url:  document.getElementById("image-url").value.trim(),
      status:     document.getElementById("status").value,
      is_featured:    document.getElementById("is-featured").checked ? 1 : 0,
      is_new_arrival: document.getElementById("is-new-arrival").checked ? 1 : 0,
      specs,
    };

    setLoading(btn, true);
    const res = await api("/api/products", { method: "POST", body: payload });

    if (res?.ok) {
      showToast("Product published!");
      setTimeout(() => window.location.href = "/admin/products/", 800);
    } else {
      showToast("Failed to save product", "error");
      setLoading(btn, false);
    }
  });
</script>
