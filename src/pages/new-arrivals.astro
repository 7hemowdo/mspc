---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactBand from "@components/ContactBand.astro";
import PageHeader from "@components/PageHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { visibleProducts } from "@data/products";

const products = visibleProducts().filter((product) => product.isNewArrival);
---

<BaseLayout
  title="New Arrivals | MSPC Gambia"
  description="Browse new electrical, networking, power backup, solar, CCTV, and technical products at MSPC Gambia."
>
  <main>
    <PageHeader
      eyebrow="Just In"
      title="New Arrivals"
      description="Recently added routers, power backup products, electrical parts, CCTV equipment, cables, and accessories."
    />
    <section class="section">
      <div class="container product-grid product-grid--four">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    </section>
    <ContactBand />
  </main>
</BaseLayout>
