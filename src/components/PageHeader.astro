---
type Props = {
  eyebrow?: string;
  title: string;
  description?: string;
};

const { eyebrow, title, description } = Astro.props;
---

<section class="page-header">
  <div class="container page-header-inner">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {description && <p>{description}</p>}
  </div>
</section>
