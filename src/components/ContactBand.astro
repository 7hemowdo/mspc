---
import { site } from "@data/site";
---

<section class="contact-band">
  <div class="container contact-band-inner">
    <div>
      <p class="eyebrow">Contact MSPC</p>
      <h2>Send a product name or category and MSPC can confirm availability.</h2>
    </div>
    <div class="contact-band-actions">
      <a class="button button--primary" href="/categories/">Browse Products</a>
      <a class="button button--whatsapp" href={site.whatsappUrl}>Contact on WhatsApp</a>
    </div>
  </div>
</section>
